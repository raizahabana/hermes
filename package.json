{
  "name": "hermes-1.0",
  "version": "1.0.0",
  "description": "Hermes 1.0 - Consolidated Architecture with OpenClaude, Openfang, and PentAgi",
  "scripts": {
    "build": "cd client && npm run build",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "cd client && npm run dev",
    "dev:api": "nodemon server/server.js",
    "start": "cd client && npm run preview",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
